# On The Porch API v3 configuration
# Copy this file to .env at the repo root and fill in the values you use locally.

# ============================================================================
# Server and app URLs
# ============================================================================
API_HOST=127.0.0.1
API_PORT=8888
APP_BASE_URL=http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8888
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# ============================================================================
# Session and token security
# ============================================================================
FLASK_SECRET_KEY=change-me-in-production
TOKEN_PEPPER=replace-with-a-separate-secret
FLASK_SESSION_COOKIE_SECURE=False
AUTH_SESSION_COOKIE_NAME=otp_session
AUTH_CSRF_COOKIE_NAME=otp_csrf
AUTH_SESSION_MAX_AGE_DAYS=7
AUTH_SESSION_SAMESITE=Lax
AUTH_LOGIN_WINDOW_MINUTES=15
AUTH_LOGIN_LOCK_THRESHOLD=5
AUTH_LOGIN_LOCK_MINUTES=15

# ============================================================================
# User authentication
# ============================================================================
# Legacy API keys are optional and only needed for old clients that still call /chat directly.
RETHINKAI_API_KEYS=legacy-api-key-1,legacy-api-key-2

# Google OAuth is optional. Leave blank to disable Google sign-in.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8888/auth/google/callback

# ============================================================================
# Database
# ============================================================================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DB=rethink_ai_boston

# ============================================================================
# Gemini models
# ============================================================================
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_SUMMARY_MODEL=gemini-3-flash-preview
GEMINI_EMBED_MODEL=models/gemini-embedding-001
